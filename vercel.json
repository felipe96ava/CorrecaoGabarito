{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/[...path].js": { "runtime": "nodejs20.x", "maxDuration": 30 },
    "api/**/*.js": { "runtime": "nodejs20.x", "maxDuration": 30 }
  }
}
